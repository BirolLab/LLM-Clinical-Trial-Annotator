# ─────────────────────────────────────────────────────────────────────────
# Agent Annotate — standalone configuration.
# Copy this file to `.env` and edit. EVERY value is optional: the API boots
# with all defaults below. The installer copies this for you.
# ─────────────────────────────────────────────────────────────────────────

# ── Server ──
# Port the app reports as its own identity in diagnostics. NOTE: this is NOT
# what uvicorn binds to — pass `--port` to uvicorn (or use ./run.sh) for that.
AGENT_ANNOTATE_PORT=9005

# ── Ollama (local LLM backend — required for annotation jobs) ──
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
# Max seconds for a single Ollama call. Large models and cold loads need
# headroom; the per-model timeouts in config/default_config.yaml refine this.
OLLAMA_TIMEOUT=600

# ── Optional research-API politeness / keys (improve throughput, not required) ──
# NCBI E-utilities key — raises PubMed rate limit from 3 to 10 req/s.
# Free: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=
# OpenAlex "polite pool" contact email (no key needed).
OPENALEX_EMAIL=
# CrossRef "polite pool" contact email.
CROSSREF_EMAIL=

# ── CORS ──
# Comma-separated origins allowed to call the API from a browser.
CORS_ORIGINS=http://localhost:5173,http://localhost:9005
